# Copy to .env and set to your machine's LAN IP (find it with: ipconfig getifaddr en0)
EXPO_PUBLIC_SERVER_HOST=192.168.x.x
EXPO_PUBLIC_SERVER_PORT=4000
# Optional: shared secret for remote access (must match AJI_ACCESS_TOKEN on the server)
EXPO_PUBLIC_SERVER_HOST=https://random-words.trycloudflare.com
EXPO_PUBLIC_SERVER_TOKEN=YOUR_TOKEN