{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "prebuildCommand": "cd apps/mobile && pnpm expo prebuild"
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "cd apps/mobile && pnpm expo prebuild"
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "cd apps/mobile && pnpm expo prebuild"
    }
  },
  "submit": {
    "production": {}
  }
}
